node_modules/
out/
dist/
.DS_Store
*.log
*.tsbuildinfo

# Claude Code tooling. The shared workflow — slash commands and skills — is
# version-controlled so it survives a fresh clone and has history. Local
# machine-specific config (permissions, settings) stays out.
.claude/*
!.claude/commands/
!.claude/skills/
.claude/settings.local.json

# Debug shell-redirect leftovers (e.g. cmd 1>b.out 2>b.err)
*.err
b.out

# Per-project runtime data (terminal layout) + agent worktrees
.monad/
.monad-worktrees/
# Stale canvas dir written by pre-rename builds
.agent-canvas/
