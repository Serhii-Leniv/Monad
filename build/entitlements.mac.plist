<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <!--
    Hardened Runtime exceptions required to notarize an Electron app.

    allow-jit / allow-unsigned-executable-memory
      V8 compiles JavaScript to executable memory at runtime. Without these the
      renderer crashes on launch under Hardened Runtime.

    allow-dyld-environment-variables
      Electron relies on dyld env vars to locate the framework inside the bundle.

    disable-library-validation
      We ship a prebuilt native module (@homebridge/node-pty-prebuilt-multiarch),
      unpacked from the asar. Library validation refuses to load a .node signed by
      a different team, which is exactly our case.

    Deliberately NOT sandboxed: Monad opens arbitrary user repos and spawns agent
    CLIs from the user's PATH. com.apple.security.app-sandbox would break both.
  -->
  <key>com.apple.security.cs.allow-jit</key>
  <true/>
  <key>com.apple.security.cs.allow-unsigned-executable-memory</key>
  <true/>
  <key>com.apple.security.cs.allow-dyld-environment-variables</key>
  <true/>
  <key>com.apple.security.cs.disable-library-validation</key>
  <true/>
</dict>
</plist>
